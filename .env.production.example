# Runtime
AGENT_TIMEZONE=America/Sao_Paulo
LOG_LEVEL=info
NODE_ENV=production

# LLM
LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_API_KEY=
BOOTSTRAP_STRICT_OLLAMA=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_MORNING_BRIEF_ENABLED=true
TELEGRAM_DAILY_EDITORIAL_AUTOMATION_ENABLED=false

# Email / Gmail
EMAIL_ENABLED=true
EMAIL_WRITE_ENABLED=true
EMAIL_ACCOUNTS=primary,abordagem

# Primary email account
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=

# Google Workspace
GOOGLE_ENABLED=true
GOOGLE_ACCOUNTS=primary,abordagem
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_OAUTH_PORT=8787
GOOGLE_CREDENTIALS_PATH=/workspace/.agent-state/google-oauth-client.json
GOOGLE_TOKEN_PATH=/workspace/.agent-state/google-oauth-token.json
GOOGLE_EXTRA_SCOPES=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ALIASES=principal:primary|pessoal:primary|personal:primary
GOOGLE_DEFAULT_TIMEZONE=America/Sao_Paulo
GOOGLE_MAX_EVENTS=10
GOOGLE_MAX_TASKS=15
GOOGLE_MAX_CONTACTS=10

# Second Google account example
# GOOGLE_ACCOUNT_ABORDAGEM_ENABLED=true
# GOOGLE_ACCOUNT_ABORDAGEM_CLIENT_ID=
# GOOGLE_ACCOUNT_ABORDAGEM_CLIENT_SECRET=
# GOOGLE_ACCOUNT_ABORDAGEM_REDIRECT_URI=
# GOOGLE_ACCOUNT_ABORDAGEM_OAUTH_PORT=8788
# GOOGLE_ACCOUNT_ABORDAGEM_CREDENTIALS_PATH=/workspace/.agent-state/google-oauth-client-abordagem.json
# GOOGLE_ACCOUNT_ABORDAGEM_TOKEN_PATH=/workspace/.agent-state/google-oauth-token-abordagem.json
# GOOGLE_ACCOUNT_ABORDAGEM_EXTRA_SCOPES=https://www.googleapis.com/auth/youtube.upload
# GOOGLE_ACCOUNT_ABORDAGEM_CALENDAR_ID=primary
# GOOGLE_ACCOUNT_ABORDAGEM_CALENDAR_ALIASES=abordagem:primary|trabalho:primary

# Maps
GOOGLE_MAPS_ENABLED=true
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DEFAULT_REGION=BR
GOOGLE_MAPS_DEFAULT_LANGUAGE=pt-BR

# Altiva / founder brief
ALTIVA_ENABLED=false
ALTIVA_COMPANY_NAME=Altiva
ALTIVA_SITE_URL=
ALTIVA_API_BASE_URL=
ALTIVA_API_KEY=
ALTIVA_SNAPSHOT_PATH=
ALTIVA_TIMEZONE=America/Sao_Paulo
ALTIVA_TRACKED_METRICS=signups,activations,active_users,paid_conversions,mrr,churn,tickets_open,tickets_urgent

# Media / stock video
MEDIA_PROVIDER_STRATEGY=balanced
MEDIA_PREMIUM_SCENE_PROVIDER=fal
PEXELS_ENABLED=false
PEXELS_API_KEY=
PEXELS_MAX_RESULTS_PER_SCENE=1
PEXELS_MAX_SCENES_PER_REQUEST=5
PEXELS_MIN_DURATION_SECONDS=4
PEXELS_CACHE_TTL_SECONDS=86400
FAL_ENABLED=false
FAL_API_KEY=
FAL_TEXT_TO_VIDEO_MODEL=fal-ai/wan/v2.7/text-to-video
FAL_REQUEST_TIMEOUT_SECONDS=45
FAL_MAX_POLL_SECONDS=300
FAL_DEFAULT_RESOLUTION=720p
KLING_ENABLED=false
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
KLING_TEXT_TO_VIDEO_MODEL=kling-v1
KLING_DIRECT_GENERATION_ENABLED=false
KLING_REQUEST_TIMEOUT_SECONDS=90
KLING_MAX_POLL_SECONDS=300

# Safe exec
SAFE_EXEC_ENABLED=true
SAFE_EXEC_ALLOWED_COMMANDS=git status --short|git branch --show-current|git diff --stat|npm run build|npm test|pnpm build|pnpm test|yarn build|yarn test
SAFE_EXEC_MAX_OUTPUT_CHARS=8000

# Supabase queue for the Mac worker
SUPABASE_MAC_QUEUE_ENABLED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MAC_COMMANDS_TABLE=mac_commands
SUPABASE_MAC_WORKERS_TABLE=mac_workers
SUPABASE_MAC_TARGET_HOST=atlas_mac
SUPABASE_MAC_POLL_SECONDS=15
SUPABASE_MAC_MAX_EXEC_SECONDS=300
SUPABASE_MAC_ALLOWED_COMMANDS=
SUPABASE_MAC_ALLOWED_CWDS=

# WhatsApp / Evolution
WHATSAPP_ENABLED=true
WHATSAPP_SIDECAR_ENABLED=true
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_SERVER_URL=http://evolution-api:8080
EVOLUTION_API_KEY=
AUTHENTICATION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
EVOLUTION_POSTGRES_DB=evolution_api
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=evolution_password
EVOLUTION_WEBHOOK_ENABLED=true
EVOLUTION_WEBHOOK_URL=http://whatsapp-sidecar:8790/webhooks/evolution
EVOLUTION_WEBHOOK_BY_EVENTS=false
EVOLUTION_WEBHOOK_EVENTS_MESSAGES_UPSERT=true
EVOLUTION_WEBHOOK_EVENTS_CONNECTION_UPDATE=true
EVOLUTION_WEBHOOK_EVENTS_QRCODE_UPDATED=true
WHATSAPP_DEFAULT_ACCOUNT=primary
WHATSAPP_INSTANCE_ACCOUNTS=
WHATSAPP_SIDECAR_PORT=8790
WHATSAPP_SIDECAR_WEBHOOK_PATH=/webhooks/evolution
WHATSAPP_NOTIFY_TELEGRAM_CHAT_ID=

# Paths inside the container
APP_HOME=/app
WORKSPACE_DIR=/workspace
PLUGINS_DIR=/plugins
LOGS_DIR=/logs
AUTHORIZED_PROJECTS_DIR=/authorized-projects
