# Container/runtime
AGENT_TIMEZONE=America/Sao_Paulo
LOG_LEVEL=info
NODE_ENV=development

# LLM provider
LLM_PROVIDER=ollama

# Ollama
# Use the native Ollama API base URL. Do not add /v1 here.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT_SECONDS=60
BOOTSTRAP_STRICT_OLLAMA=true

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_API_KEY=

# Optional external reasoning provider
EXTERNAL_REASONING_ENABLED=false
EXTERNAL_REASONING_BASE_URL=
EXTERNAL_REASONING_API_KEY=
EXTERNAL_REASONING_TIMEOUT_MS=20000
EXTERNAL_REASONING_ROUTE_SIMPLE_READS=false

# Telegram will be used in PASSO 3.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_OPERATIONAL_MODE_HOURS=18

# Async Telegram voice input. Provider can be openai or command.
VOICE_ENABLED=false
VOICE_STT_PROVIDER=openai
VOICE_MAX_AUDIO_SECONDS=90
VOICE_MAX_AUDIO_BYTES=15728640
VOICE_TEMP_DIR=/workspace/.agent-state/voice-temp
VOICE_STT_TIMEOUT_MS=120000
VOICE_OPENAI_MODEL=gpt-4o-mini-transcribe
VOICE_STT_COMMAND=
VOICE_STT_ARGS=

EMAIL_ENABLED=false
EMAIL_ACCOUNTS=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_LOOKBACK_HOURS=72
EMAIL_MAX_MESSAGES=10
EMAIL_MAX_SOURCE_BYTES=200000
EMAIL_MAX_TEXT_CHARS=12000
EMAIL_WRITE_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_NAME=
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_ALLOWED_SENDERS=
EMAIL_REPLY_ALLOWED_DOMAINS=

# Example second email account:
# EMAIL_ACCOUNT_CLINICA_ENABLED=true
# EMAIL_ACCOUNT_CLINICA_IMAP_HOST=imap.gmail.com
# EMAIL_ACCOUNT_CLINICA_IMAP_PORT=993
# EMAIL_ACCOUNT_CLINICA_IMAP_SECURE=true
# EMAIL_ACCOUNT_CLINICA_IMAP_USERNAME=clinica.agenda.psico@gmail.com
# EMAIL_ACCOUNT_CLINICA_IMAP_PASSWORD=
# EMAIL_ACCOUNT_CLINICA_IMAP_MAILBOX=INBOX
# EMAIL_ACCOUNT_CLINICA_SMTP_HOST=smtp.gmail.com
# EMAIL_ACCOUNT_CLINICA_SMTP_PORT=465
# EMAIL_ACCOUNT_CLINICA_SMTP_SECURE=true
# EMAIL_ACCOUNT_CLINICA_SMTP_USERNAME=clinica.agenda.psico@gmail.com
# EMAIL_ACCOUNT_CLINICA_SMTP_PASSWORD=
# EMAIL_ACCOUNT_CLINICA_FROM_NAME=Agenda Clinica
# EMAIL_ACCOUNT_CLINICA_FROM_ADDRESS=clinica.agenda.psico@gmail.com

GOOGLE_ENABLED=false
GOOGLE_ACCOUNTS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_OAUTH_PORT=8787
GOOGLE_CREDENTIALS_PATH=/workspace/.agent-state/google-oauth-client.json
GOOGLE_TOKEN_PATH=/workspace/.agent-state/google-oauth-token.json
GOOGLE_EXTRA_SCOPES=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ALIASES=principal:primary|pessoal:primary|personal:primary
GOOGLE_DEFAULT_TIMEZONE=America/Sao_Paulo
GOOGLE_MAX_EVENTS=10
GOOGLE_MAX_TASKS=15
GOOGLE_MAX_CONTACTS=10

GOOGLE_MAPS_ENABLED=false
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DEFAULT_REGION=BR
GOOGLE_MAPS_DEFAULT_LANGUAGE=pt-BR

# Media / stock video
PEXELS_ENABLED=false
PEXELS_API_KEY=
PEXELS_MAX_RESULTS_PER_SCENE=1
PEXELS_MAX_SCENES_PER_REQUEST=5
PEXELS_MIN_DURATION_SECONDS=4
PEXELS_CACHE_TTL_SECONDS=86400

# Example second Google account:
# GOOGLE_ACCOUNT_CLINICA_ENABLED=true
# GOOGLE_ACCOUNT_CLINICA_CLIENT_ID=
# GOOGLE_ACCOUNT_CLINICA_CLIENT_SECRET=
# GOOGLE_ACCOUNT_CLINICA_REDIRECT_URI=http://127.0.0.1:8788/oauth2callback
# GOOGLE_ACCOUNT_CLINICA_OAUTH_PORT=8788
# GOOGLE_ACCOUNT_CLINICA_CREDENTIALS_PATH=/workspace/.agent-state/google-oauth-client-clinica.json
# GOOGLE_ACCOUNT_CLINICA_TOKEN_PATH=/workspace/.agent-state/google-oauth-token-clinica.json
# GOOGLE_ACCOUNT_CLINICA_EXTRA_SCOPES=https://www.googleapis.com/auth/youtube.upload
# GOOGLE_ACCOUNT_CLINICA_CALENDAR_ID=primary
# GOOGLE_ACCOUNT_CLINICA_CALENDAR_ALIASES=principal:primary|clinica:primary

SAFE_EXEC_ENABLED=true
SAFE_EXEC_ALLOWED_COMMANDS=git status --short|git branch --show-current|git diff --stat|npm ci|npm install|npm run build|npm test|pnpm install|pnpm build|pnpm test|yarn install|yarn build|yarn test
SAFE_EXEC_MAX_OUTPUT_CHARS=8000

SUPABASE_MAC_QUEUE_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MAC_COMMANDS_TABLE=mac_commands
SUPABASE_MAC_WORKERS_TABLE=mac_workers
SUPABASE_MAC_TARGET_HOST=atlas_mac
SUPABASE_MAC_POLL_SECONDS=15
SUPABASE_MAC_MAX_EXEC_SECONDS=300
SUPABASE_MAC_ALLOWED_COMMANDS=open -a|open -g|open|code|git status|git branch --show-current|npm run build|npm run dev|npm test|pnpm build|pnpm dev|pnpm test|yarn build|yarn dev|yarn test|osascript -e
SUPABASE_MAC_ALLOWED_CWDS=/Users/SEU_USUARIO/Documents,/Users/SEU_USUARIO/Agente_Workspace,/Users/SEU_USUARIO/Agente_Autorizados

WHATSAPP_ENABLED=true
EVOLUTION_API_URL=http://host.docker.internal:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=atlas_prime
WHATSAPP_DEFAULT_ACCOUNT=primary
WHATSAPP_INSTANCE_ACCOUNTS=atlas_prime:primary|atlas_abordagem:abordagem
WHATSAPP_SIDECAR_ENABLED=false
WHATSAPP_CONVERSATION_ENABLED=false
WHATSAPP_ALLOWED_NUMBERS=
WHATSAPP_UNAUTHORIZED_MODE=ignore
WHATSAPP_IGNORE_GROUPS=true
WHATSAPP_SIDECAR_PORT=8790
WHATSAPP_SIDECAR_WEBHOOK_PATH=/webhooks/evolution
WHATSAPP_NOTIFY_TELEGRAM_CHAT_ID=

# Secure host mounts
HOST_AGENT_WORKSPACE=/Users/SEU_USUARIO/Agente_Workspace
HOST_AGENT_PLUGINS=/Users/SEU_USUARIO/Agente_Plugins
HOST_AGENT_LOGS=/Users/SEU_USUARIO/Agente_Logs
HOST_AUTHORIZED_PROJECTS_DIR=/Users/SEU_USUARIO/Agente_Autorizados
HOST_USER_DOCUMENTS_DIR=/Users/SEU_USUARIO/Documents
